# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Environments
.venv/
venv/
env/

# Tooling
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local
*.log
.DS_Store

# Secrets — never commit API keys (LangSmith, Anthropic, OpenAI, git tokens). Keep them in a
# local .env (or the shell) that stays out of git; commit only a redacted .env.example.
.env
.env.*
!.env.example
*.key
secrets/

# Fleet: the repo-local kubeconfig — the primary cluster-isolation guarantee. kind writes the
# loopkit cluster's credentials ONLY here (KUBECONFIG points at it), so ~/.kube/config is never
# touched, merged, or put at risk. Never commit it.
.kube/
