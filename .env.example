# loopkit environment — copy to `.env` and fill in. `.env` is gitignored; never commit real keys.
# These are read from the process environment; loopkit does not load .env itself (use direnv,
# `set -a; . ./.env; set +a`, or your shell) — the names below are what loopkit/SDKs look for.

# --- LangSmith tracing (optional; loopkit[trace]) -------------------------------------------------
# Tracing auto-activates when langsmith is installed AND a key (or LANGSMITH_TRACING) is present.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=loop-kit

# --- Agent provider keys (only the adapter you run needs its key) --------------------------------
# claude-code / claude-api  -> ANTHROPIC_API_KEY (or CLAUDE_CODE_OAUTH_TOKEN for the subscription)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# openai-api / codex        -> OPENAI_API_KEY
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
